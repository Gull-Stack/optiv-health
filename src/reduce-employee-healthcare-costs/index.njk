<script>
// Enhanced calculator
function calculateSavings() {
  const employees = parseInt(document.getElementById('employees')?.value) || 0;
  const avgWage = parseInt(document.getElementById('avgWage')?.value) || 45000;
  
  if (employees > 0) {
    // FICA savings calculation (7.65% on $1,200 annual contribution per employee)
    const ficaSavings = employees * 1200 * 0.0765;
    
    // Healthcare cost reduction ($600 average per employee)
    const healthcareSavings = employees * 600;
    
    // Total savings
    const totalSavings = ficaSavings + healthcareSavings;
    
    document.getElementById('ficaSavings').textContent = '$' + Math.round(ficaSavings).toLocaleString();
    document.getElementById('healthcareSavings').textContent = '$' + healthcareSavings.toLocaleString();
    document.getElementById('totalSavings').textContent = '$' + Math.round(totalSavings).toLocaleString();
  } else {
    document.getElementById('ficaSavings').textContent = '$0';
    document.getElementById('healthcareSavings').textContent = '$0';
    document.getElementById('totalSavings').textContent = '$0';
  }
}

document.getElementById('employees')?.addEventListener('input', calculateSavings);
document.getElementById('avgWage')?.addEventListener('input', calculateSavings);
</script>

