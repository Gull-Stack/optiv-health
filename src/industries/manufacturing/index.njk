<script>
// Manufacturing ROI Calculator
function calculateManufacturingROI() {
  const employees = parseInt(document.getElementById('mfg-employees')?.value) || 0;
  const shifts = parseInt(document.getElementById('shifts')?.value) || 1;
  const hourlyWage = parseFloat(document.getElementById('avg-wage')?.value) || 22;
  
  if (employees > 0) {
    // Calculate annual wages
    const annualWage = hourlyWage * 40 * 52; // 40 hours/week, 52 weeks/year
    
    // FICA savings (7.65% on $1,200 annual contribution per employee)
    const ficaSavings = employees * 1200 * 0.0765;
    
    // Healthcare cost reduction (higher for shift work due to urgent care savings)
    const healthcareReduction = employees * (shifts > 1 ? 800 : 600);
    
    // Turnover cost savings (manufacturing turnover is expensive)
    // Assume 25% of employees would have turned over, $15k cost per turnover
    // Benefits reduce turnover by 30%
    const turnoverSavings = (employees * 0.25 * 0.30 * 15000);
    
    const totalSavings = ficaSavings + healthcareReduction + turnoverSavings;
    
    document.getElementById('fica-savings').textContent = '$' + Math.round(ficaSavings).toLocaleString();
    document.getElementById('healthcare-reduction').textContent = '$' + healthcareReduction.toLocaleString();
    document.getElementById('turnover-savings').textContent = '$' + Math.round(turnoverSavings).toLocaleString();
    document.getElementById('total-mfg-savings').textContent = '$' + Math.round(totalSavings).toLocaleString();
  } else {
    document.getElementById('fica-savings').textContent = '$0';
    document.getElementById('healthcare-reduction').textContent = '$0';
    document.getElementById('turnover-savings').textContent = '$0';
    document.getElementById('total-mfg-savings').textContent = '$0';
  }
}

document.getElementById('mfg-employees')?.addEventListener('input', calculateManufacturingROI);
document.getElementById('shifts')?.addEventListener('change', calculateManufacturingROI);
document.getElementById('avg-wage')?.addEventListener('input', calculateManufacturingROI);
</script>

